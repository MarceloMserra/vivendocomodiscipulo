<!DOCTYPE html>
<html lang="pt-br" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#0F172A">

    <title>Vivendo como Discípulo 2.0</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            dark: '#0F172A',     // Slate 900
                            primary: '#3B82F6',  // Blue 500
                            accent: '#F59E0B',   // Amber 500
                            glass: 'rgba(30, 41, 59, 0.7)'
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-out',
                        'slide-up': 'slideUp 0.5s ease-out',
                    },
                    keyframes: {
                        fadeIn: { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
                        slideUp: { '0%': { transform: 'translateY(20px)', opacity: '0' }, '100%': { transform: 'translateY(0)', opacity: '1' } }
                    }
                }
            }
        }
    </script>

    <!-- Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@700&display=swap"
        rel="stylesheet">

    <style>
        body {
            background-color: #0F172A;
            color: #F8FAFC;
        }

        /* Premium Glass Effect */
        .glass-panel {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #475569;
        }
    </style>
</head>

<body class="antialiased min-h-screen relative overflow-x-hidden selection:bg-brand-accent selection:text-brand-dark">

    <!-- Background Gradients -->
    <div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] right-[-10%] w-96 h-96 bg-purple-500/20 rounded-full blur-3xl animate-pulse">
        </div>
        <div class="absolute bottom-[-10%] left-[-10%] w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
    </div>

    <!-- Main Container -->
    <div id="app-container"
        class="max-w-md mx-auto min-h-screen relative flex flex-col glass-panel md:border-x md:border-white/5 shadow-2xl">

        <!-- Header -->
        <header
            class="p-6 flex justify-between items-center sticky top-0 z-40 bg-brand-dark/80 backdrop-blur-md border-b border-white/5">
            <div>
                <p class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-1">Igreja Memorial</p>
                <h1 class="text-xl font-serif font-bold text-white leading-none">Discípulo</h1>
            </div>

            <button
                class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition overflow-hidden">
                <img src="https://ui-avatars.com/api/?name=User&background=random" alt="Profile"
                    class="w-full h-full object-cover opacity-80 hover:opacity-100 transition">
            </button>
        </header>

        <!-- Content -->
        <main class="flex-1 p-4 pb-24 overflow-y-auto">
            {{{body}}}
        </main>

        <!-- Bottom Nav -->
        <nav
            class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-[380px] h-16 glass-panel rounded-full flex justify-around items-center z-50 px-2">
            <a href="/"
                class="nav-item active flex flex-col items-center justify-center w-12 h-12 rounded-full text-brand-primary">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6">
                    </path>
                </svg>
            </a>
            <a href="/pgm"
                class="nav-item flex flex-col items-center justify-center w-12 h-12 rounded-full text-gray-400 hover:text-white transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                    </path>
                </svg>
            </a>
            <a href="/profile"
                class="nav-item flex flex-col items-center justify-center w-12 h-12 rounded-full text-gray-400 hover:text-white transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </a>
        </nav>

    </div>

    <!-- Toast Container -->
    <!-- Toast Container -->
    <div id="toast-container"
        class="fixed top-4 left-1/2 -translate-x-1/2 z-[60] flex flex-col gap-2 w-[90%] max-w-sm pointer-events-none">
    </div>

    <script>
        window.showToast = function (message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            const colors = type === 'error' ? 'bg-red-500 text-white' : 'bg-green-500 text-white';
            toast.className = `pointer-events-auto p-4 rounded-xl shadow-2xl flex items-center justify-between gap-3 transform translate-y-[-100%] transition-all duration-300 \${colors}`;
            toast.innerHTML = `<span class="font-bold text-sm">\${message}</span>`;

            container.appendChild(toast);
            requestAnimationFrame(() => toast.classList.remove('translate-y-[-100%]'));

            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
    <script type="module" src="/js/auth-context.js"></script>
</body>

</html>