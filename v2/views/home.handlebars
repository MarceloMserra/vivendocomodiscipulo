{{#if data}}
<!-- Header Card -->
<div class="mb-8 animate-fade-in">
    <div class="glass-panel p-6 rounded-3xl relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-brand-primary/20 rounded-full blur-2xl -mr-16 -mt-16"></div>

        <span class="relative z-10 text-[10px] uppercase tracking-wider text-brand-accent font-bold">Leitura da
            Semana</span>
        <h2 class="relative z-10 text-2xl font-serif font-bold mt-1 text-white">{{data.semana}}</h2>

        <div class="mt-4 flex gap-2">
            <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] font-bold text-white/70">
                {{data.devocionais.length}} leituras
            </span>
            {{#if data.noticias}}
            <span
                class="px-3 py-1 rounded-full bg-brand-accent/20 border border-brand-accent/20 text-[10px] font-bold text-brand-accent">
                {{data.noticias.length}} novidades
            </span>
            {{/if}}
        </div>
    </div>
</div>

<!-- News Section -->
{{#if data.noticias}}
<div class="mb-10 animate-fade-in" style="animation-delay: 0.1s">
    <h3 class="font-bold text-white text-sm uppercase tracking-wide mb-4 flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-accent"></span> Destaques
    </h3>

    <div class="flex overflow-x-auto gap-4 pb-4 snap-x snap-mandatory no-scrollbar">
        {{#each data.noticias}}
        <div
            class="min-w-[280px] glass-panel p-5 rounded-2xl snap-center flex flex-col justify-between border border-white/5 hover:border-white/20 transition group">
            <div>
                <span class="text-[9px] font-bold text-brand-accent uppercase mb-2 block">{{this.data}}</span>
                <h4 class="font-bold text-white leading-tight mb-2 line-clamp-2">{{this.titulo}}</h4>
                <p class="text-xs text-gray-400 line-clamp-3">{{this.conteudo}}</p>
            </div>
            {{#if this.link}}
            <a href="https://{{this.link}}" target="_blank"
                class="mt-4 text-[10px] font-bold text-brand-primary hover:text-white transition flex items-center gap-1">
                ACESSAR LINK <span>→</span>
            </a>
            {{/if}}
        </div>
        {{/each}}
    </div>
</div>
{{/if}}

<!-- Devotionals List -->
<div class="space-y-4 pb-12 animate-fade-in" style="animation-delay: 0.2s">
    <h3 class="font-bold text-white text-sm uppercase tracking-wide mb-2 flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-primary"></span> Leituras Diárias
    </h3>

    {{#each data.devocionais}}
    <div onclick='openReader({{@index}}, {{json this}})'
        class="glass-panel p-5 rounded-2xl cursor-pointer hover:bg-white/5 transition border border-white/5 group relative overflow-hidden">

        <div class="flex justify-between items-start relative z-10">
            <div>
                <span class="text-[10px] font-bold text-gray-400 uppercase">{{this.cabecalho_dia}}</span>
                <h3 class="text-lg font-bold text-white mt-1 group-hover:text-brand-primary transition">{{this.titulo}}
                </h3>
                <p class="text-xs text-gray-500 italic mt-1 font-serif">"{{this.texto_base}}"</p>
            </div>
            <!-- Check Indicator -->
            <div id="check-{{@index}}"
                class="w-6 h-6 rounded-full border border-white/20 flex items-center justify-center text-transparent transition-all">
                ✓
            </div>
        </div>
    </div>
    {{/each}}
</div>
{{else}}
<div class="flex flex-col items-center justify-center h-64 text-center">
    <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center text-2xl mb-4 animate-bounce">📅
    </div>
    <h2 class="text-white font-bold">Nenhum boletim encontrado</h2>
    <p class="text-gray-400 text-sm mt-2">Aguarde a publicação desta semana.</p>
</div>
{{/if}}

<!-- Reader Modal (Simplified & Modern) -->
<div id="readerModal"
    class="fixed inset-0 z-50 translate-y-full transition-transform duration-300 flex flex-col bg-[#0F172A]">
    <!-- Modal Header -->
    <div
        class="flex justify-between items-center p-6 border-b border-white/5 bg-[#0F172A]/90 backdrop-blur-md sticky top-0 z-10">
        <button onclick="closeReader()"
            class="p-2 rounded-full bg-white/5 hover:bg-white/10 text-white transition">↓</button>
        <span id="modalDate" class="text-xs font-bold text-gray-400 uppercase"></span>
        <div class="w-8"></div>
    </div>

    <!-- Modal Content -->
    <div class="flex-1 overflow-y-auto p-6 pb-24">
        <h1 id="modalTitle" class="text-3xl font-serif font-bold text-white mb-6 leading-tight"></h1>

        <div class="prose prose-invert prose-lg max-w-none text-gray-300 font-serif leading-relaxed" id="modalText">
        </div>

        <div class="mt-12 pt-8 border-t border-white/5">
            <button id="markReadBtn" onclick="toggleRead()"
                class="w-full py-4 rounded-xl font-bold transition flex items-center justify-center gap-2 border border-white/20 hover:bg-white/5">
                Marcar como Lido
            </button>
        </div>
    </div>
</div>

<script>
    let currentIndex = null;

    function openReader(index, data) {
        currentIndex = index;
        document.getElementById('modalDate').innerText = data.cabecalho_dia;
        document.getElementById('modalTitle').innerText = data.titulo;
        document.getElementById('modalText').innerHTML = data.conteudo.replace(/\n/g, '<br><br>');

        // Check Status
        updateReadButton();

        document.getElementById('readerModal').classList.remove('translate-y-full');
    }

    function closeReader() {
        document.getElementById('readerModal').classList.add('translate-y-full');
    }

    function toggleRead() {
        if (currentIndex === null) return;
        const key = `read_v2_${currentIndex}`; // New key for V2
        const isRead = localStorage.getItem(key) === 'true';

        if (isRead) localStorage.removeItem(key);
        else localStorage.setItem(key, 'true');

        updateReadButton();
        updateListCheck(currentIndex);
    }

    function updateReadButton() {
        const key = `read_v2_${currentIndex}`;
        const isRead = localStorage.getItem(key) === 'true';
        const btn = document.getElementById('markReadBtn');

        if (isRead) {
            btn.className = "w-full py-4 rounded-xl font-bold transition flex items-center justify-center gap-2 bg-green-600 text-white border-0 shadow-lg shadow-green-900/20";
            btn.innerHTML = "✓ Leitura Concluída";
        } else {
            btn.className = "w-full py-4 rounded-xl font-bold transition flex items-center justify-center gap-2 border border-white/20 hover:bg-white/5 text-gray-300";
            btn.innerHTML = "○ Marcar como Lido";
        }
    }

    function updateListCheck(index) {
        const key = `read_v2_${index}`;
        const isRead = localStorage.getItem(key) === 'true';
        const el = document.getElementById(`check-${index}`);
        if (!el) return;

        if (isRead) {
            el.classList.add('bg-green-500', 'text-white', 'border-transparent');
        } else {
            el.classList.remove('bg-green-500', 'text-white', 'border-transparent');
        }
    }

    // Init Logic
    document.addEventListener('DOMContentLoaded', () => {
        // Sync checks
        for (let i = 0; i < 20; i++) updateListCheck(i); // Check first 20 just in case
    });
</script>