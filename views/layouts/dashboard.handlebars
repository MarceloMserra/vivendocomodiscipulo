<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">

    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Discípulo">
    <meta name="theme-color" content="#0F265C">

    <link rel="apple-touch-icon" href="/img/icon-192.png">
    <link rel="manifest" href="/manifest.json">

    <title>Vivendo como Discípulo - Dashboard</title>

    <link rel="stylesheet" href="/css/styles.css">
    <style>
        body {
            padding-top: env(safe-area-inset-top);
            padding-bottom: env(safe-area-inset-bottom);
            min-height: 100vh;
        }

        .app-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background-color: #0F265C;
            background-image: url('/img/background.webp');
            background-repeat: no-repeat;
            background-position: center center;
            background-size: cover;
        }

        @supports not (background-image: url('/img/background.webp')) {
            .app-bg { background-image: url('/img/background.jpg'); }
        }

        .app-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), rgba(15, 38, 92, 0.6));
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }

        @media (min-width: 768px) {
            .glass-panel {
                backdrop-filter: blur(6px);
                -webkit-backdrop-filter: blur(6px);
            }
        }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        .nav-link { color: rgba(255,255,255,0.45); }
        .nav-link svg, .nav-link span { transition: all 0.2s; }
        .nav-link.active { color: #C5A059; }
        .nav-link.active svg { filter: drop-shadow(0 0 6px rgba(197,160,89,0.5)); }
        .nav-link:hover { color: rgba(255,255,255,0.8); }
    </style>
</head>

<body class="text-white font-sans antialiased overflow-hidden">

    <div class="app-bg"></div>
    <div class="app-overlay"></div>

    <!-- MAIN CONTAINER: Changed from max-w-md to w-full for Dashboard Layout -->
    <div class="w-full h-screen flex flex-col relative">

        <header class="p-6 pt-10 shrink-0 relative z-10 flex justify-between items-center max-w-7xl mx-auto w-full">
            <div onclick="window.location.href='/profile'" class="cursor-pointer">
                <p class="text-[10px] text-imbb-gold uppercase tracking-[0.2em] font-bold opacity-90">IGREJA MEMORIAL
                    BATISTA</p>
                <h1 id="userGreeting" class="text-2xl font-serif font-bold text-white drop-shadow-md mt-1">Bem-vindo
                </h1>
            </div>

            <a href="/profile"
                class="h-11 w-11 rounded-full border border-white/30 p-0.5 overflow-hidden shadow-lg hover:border-imbb-gold transition glass-panel flex items-center justify-center">
                <img id="headerProfileImg" src="" class="w-full h-full rounded-full object-cover hidden">
                <div id="headerInitials" class="text-white font-serif font-bold text-lg">?</div>
            </a>
        </header>

        <main class="flex-1 overflow-y-auto no-scrollbar relative w-full">
            {{{body}}}
        </main>

        <nav id="bottomNav" class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-7xl z-50 hidden">
            <div class="bg-[#070F24]/95 border-t border-white/10 shadow-2xl px-2" style="padding-bottom: max(env(safe-area-inset-bottom), 8px)">
                <div class="flex justify-around items-center h-16 max-w-lg mx-auto">

                    <a href="/" id="nav-home" class="nav-link flex flex-col items-center justify-center gap-0.5 px-3 py-2 rounded-xl min-w-[56px] transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                        <span class="text-[10px] font-semibold tracking-wide">Início</span>
                    </a>

                    <a href="/pgm" id="nav-pgm" class="nav-link flex flex-col items-center justify-center gap-0.5 px-3 py-2 rounded-xl min-w-[56px] transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
                        <span class="text-[10px] font-semibold tracking-wide">PGM</span>
                    </a>

                    <a href="/oracao" id="nav-oracao" class="nav-link flex flex-col items-center justify-center gap-0.5 px-3 py-2 rounded-xl min-w-[56px] transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
                        <span class="text-[10px] font-semibold tracking-wide">Oração</span>
                    </a>

                    <a href="/gestao" id="nav-gestao" class="nav-link hidden flex-col items-center justify-center gap-0.5 px-3 py-2 rounded-xl min-w-[56px] transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/></svg>
                        <span class="text-[10px] font-semibold tracking-wide">Gestão</span>
                    </a>

                    <a href="/admin" id="nav-admin" class="nav-link hidden flex-col items-center justify-center gap-0.5 px-3 py-2 rounded-xl min-w-[56px] transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                        <span class="text-[10px] font-semibold tracking-wide">Upload</span>
                    </a>

                    <a href="/monitoring" id="nav-monitor" class="nav-link hidden flex-col items-center justify-center gap-0.5 px-3 py-2 rounded-xl min-w-[56px] transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        <span class="text-[10px] font-semibold tracking-wide">Freq.</span>
                    </a>

                    <a href="/profile" id="nav-profile" class="nav-link flex flex-col items-center justify-center gap-0.5 px-3 py-2 rounded-xl min-w-[56px] transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                        <span class="text-[10px] font-semibold tracking-wide">Perfil</span>
                    </a>

                </div>
            </div>
        </nav>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, doc, getDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyCTB6wkVIfnwx009A67bv8Ar58YpD-59Z8",
            authDomain: "vivendo-como-discipulo.firebaseapp.com",
            projectId: "vivendo-como-discipulo",
            storageBucket: "vivendo-como-discipulo.firebasestorage.app",
            messagingSenderId: "1086407430526",
            appId: "1:1086407430526:web:d57784df6283c51729a32f",
            measurementId: "G-5JV8QRSMXQ"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('Service Worker Registrado!', reg))
                    .catch(err => console.log('Erro Service Worker:', err));
            });
        }

        function applyActiveNav() {
            const path = window.location.pathname;
            const map = { '/': 'nav-home', '/pgm': 'nav-pgm', '/oracao': 'nav-oracao', '/gestao': 'nav-gestao', '/admin': 'nav-admin', '/monitoring': 'nav-monitor', '/profile': 'nav-profile' };
            const activeId = Object.entries(map).find(([p]) => path === p || (p !== '/' && path.startsWith(p)))?.[1];
            if (activeId) document.getElementById(activeId)?.classList.add('active');
        }
        applyActiveNav();

        function applyNavRole(role) {
            const isAdmin = role === 'admin';
            const isSupervisor = role === 'supervisor' || role === 'admin';
            const isLeader = role === 'lider' || role === 'admin' || role === 'supervisor';

            if (isLeader) { const el = document.getElementById('nav-monitor'); el.classList.remove('hidden'); el.classList.add('flex'); }
            if (isAdmin) {
                const ga = document.getElementById('nav-admin'); ga.classList.remove('hidden'); ga.classList.add('flex');
                const gg = document.getElementById('nav-gestao'); gg.classList.remove('hidden'); gg.classList.add('flex');
            } else if (isSupervisor) {
                const gg = document.getElementById('nav-gestao'); gg.classList.remove('hidden'); gg.classList.add('flex');
            }
        }

        onAuthStateChanged(auth, async (user) => {
            if (user) {
                user.getIdToken().then(token => {
                    document.cookie = `session=${token}; path=/; max-age=3600; SameSite=Strict`;
                }).catch(() => {});

                // Mostra nav imediatamente com role do localStorage
                const cachedRole = localStorage.getItem('userRole');
                if (cachedRole) applyNavRole(cachedRole);

                document.getElementById('bottomNav').classList.remove('hidden');
                document.getElementById('bottomNav').classList.add('block');

                try {
                    const userDoc = await getDoc(doc(db, "users", user.uid));
                    if (userDoc.exists()) {
                        const d = userDoc.data();
                        const fullName = d.name || d.displayName || "Usuário";
                        document.getElementById('userGreeting').innerText = `Olá, ${fullName.split(' ')[0]}!`;

                        let normalizedRole = d.role;
                        if (!normalizedRole || normalizedRole === 'undefined') {
                            if (d.roles?.admin) normalizedRole = 'admin';
                            else if (d.roles?.supervisor) normalizedRole = 'supervisor';
                            else if (d.roles?.lider || d.roles?.leader) normalizedRole = 'lider';
                            else normalizedRole = 'membro';
                        }
                        localStorage.setItem('userUid', user.uid);
                        localStorage.setItem('userName', fullName);
                        localStorage.setItem('userRole', normalizedRole);

                        const photo = d.photoUrl && !d.photoUrl.startsWith('data:') ? d.photoUrl
                                    : d.photoURL && !d.photoURL.startsWith('data:') ? d.photoURL
                                    : null;
                        if (photo) {
                            document.getElementById('headerProfileImg').src = photo;
                            document.getElementById('headerProfileImg').classList.remove('hidden');
                            document.getElementById('headerInitials').classList.add('hidden');
                        }

                        applyNavRole(normalizedRole);
                    }
                } catch (e) { console.error('Nav error:', e); }
            } else if (!['/login', '/register'].includes(window.location.pathname)) {
                window.location.href = '/login';
            }
        });
        window.logout = () => signOut(auth).then(() => { localStorage.clear(); window.location.href = '/login'; });
    </script>
</body>

</html>