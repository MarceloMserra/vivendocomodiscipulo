<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rede de Discipulado | Mapa V3</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'imbb-navy': '#0A1128',
                        'imbb-blue': '#1C2B4B',
                        'imbb-gold': '#D4AF37',
                    },
                    fontFamily: {
                        sans: ['Roboto', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background: #0A1128;
            font-family: 'Roboto', sans-serif;
        }

        .node circle {
            fill: #0A1128;
            stroke: #D4AF37;
            stroke-width: 2px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .node circle:hover {
            fill: #D4AF37;
            stroke: white;
        }

        .node text {
            font-size: 10px;
            font-weight: bold;
            fill: rgba(255, 255, 255, 0.8);
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
            pointer-events: none;
        }

        .link {
            fill: none;
            stroke: rgba(255, 255, 255, 0.15);
            stroke-width: 1.5px;
            transition: all 0.5s;
        }

        .avatar-group {
            pointer-events: none;
        }

        .control-panel {
            position: absolute;
            bottom: 20px;
            right: 20px;
            z-index: 100;
            display: flex;
            gap: 10px;
        }

        .btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s;
            backdrop-filter: blur(5px);
        }

        .btn:hover {
            background: #D4AF37;
            color: #0A1128;
            border-color: #D4AF37;
        }

        #loading {
            position: fixed;
            inset: 0;
            background: #0A1128;
            z-index: 999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(212, 175, 55, 0.3);
            border-top-color: #D4AF37;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>

<body>

    <div id="loading">
        <div class="spinner"></div>
        <p class="text-imbb-gold text-xs font-bold tracking-[0.2em] uppercase animate-pulse">Carregando Rede...</p>
    </div>

    <div class="absolute top-5 left-5 z-50">
        <a href="/gestao"
            class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full hover:bg-white/10 transition backdrop-blur-md">
            <span class="text-imbb-gold text-lg">←</span>
            <span class="text-white text-xs font-bold uppercase tracking-wide">Voltar para Gestão</span>
        </a>
    </div>

    <!-- Container do SVG -->
    <div id="tree-container" class="w-screen h-screen"></div>

    <div class="control-panel">
        <button class="btn" onclick="zoomIn()">+</button>
        <button class="btn" onclick="zoomOut()">-</button>
        <button class="btn" onclick="resetZoom()">⟲</button>
    </div>

    <script>
        // Configuração D3
        const width = window.innerWidth;
        const height = window.innerHeight;
        let svg, g, zoom;

        async function init() {
            const uid = localStorage.getItem('userUid');
            if (!uid) { window.location.href = '/login'; return; }

            // Fetch Data
            try {
                const res = await fetch('/api/rede/tree', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ uid })
                });
                const data = await res.json();

                if (!data || data.error) throw new Error(data.error || "Erro de dados");

                document.getElementById('loading').style.opacity = 0;
                setTimeout(() => document.getElementById('loading').remove(), 500);

                renderTree(data);
            } catch (e) {
                alert("Erro ao carregar mapa: " + e.message);
                window.location.href = '/pgm';
            }
        }

        function renderTree(treeData) {
            // Hierarquia
            const root = d3.hierarchy(treeData);

            // HORIZONTAL LAYOUT
            // In D3 tree, size is [height, width] for vertical, but for horizontal we swap x/y logic manually.
            // Setup: Increased node separation
            const nodeHeight = 50;
            const nodeWidth = 250;

            // Calculate dynamic height based on number of leaves to avoid overlap
            // Count total leaf nodes (end nodes)
            let leaves = 0;
            root.each(d => { if (!d.children && !d._children) leaves++; });
            const dynamicHeight = Math.max(height, leaves * nodeHeight);

            // Tree Layout
            const treeLayout = d3.tree().size([dynamicHeight, width * 0.8]);

            // Initial Expand/Collapse
            root.descendants().forEach((d, i) => {
                d.id = i;
                // Collapse deeper levels if needed
                if (d.depth > 1) d._children = d.children; // Collapse PGMs initially? Maybe not.
            });

            svg = d3.select("#tree-container").append("svg")
                .attr("width", width)
                .attr("height", height)
                .call(d3.zoom().on("zoom", (e) => g.attr("transform", e.transform)));

            // Shift right slightly
            const initialTransform = d3.zoomIdentity.translate(80, height / 2).scale(0.8);
            svg.call(d3.zoom().transform, initialTransform);

            g = svg.append("g");

            update(root);

            function update(source) {
                const nodes = root.descendants();
                const links = root.links();

                treeLayout(root);

                // --- LINKS ---
                // Horizontal Link: curve from (y, x) to (y, x) because we swap coords for display
                const link = g.selectAll(".link")
                    .data(links, d => d.target.id);

                const linkEnter = link.enter().insert("path", "g")
                    .attr("class", "link")
                    .attr("d", d => {
                        const o = { x: source.x0 || source.x, y: source.y0 || source.y };
                        return horizontalDiagonal(o, o);
                    });

                const linkUpdate = link.merge(linkEnter);
                // Transition to new position (Swapped X/Y for Horizontal: d.x is vertical pos, d.y is horizontal pos)
                linkUpdate.transition().duration(500)
                    .attr("d", d => horizontalDiagonal(d.source, d.target));

                link.exit().transition().duration(500)
                    .attr("d", d => {
                        const o = { x: source.x, y: source.y };
                        return horizontalDiagonal(o, o);
                    })
                    .remove();

                // --- NODES ---
                const node = g.selectAll(".node")
                    .data(nodes, d => d.id);

                // Enter: Start at source position
                const nodeEnter = node.enter().append("g")
                    .attr("class", "node")
                    .attr("transform", d => `translate(${source.y0 || source.y},${source.x0 || source.x})`)
                    .on("click", click);

                // Node Circle
                nodeEnter.append("circle")
                    .attr("r", 1e-6)
                    .style("fill", d => d._children ? "#D4AF37" : "#0A1128")
                    .style("stroke", d => {
                        if (d.data.role === 'Supervisor') return '#3B82F6';
                        if (d.data.role === 'PGM') return '#D4AF37';
                        return '#FFF';
                    });

                // Avatar/Icon Support
                const defs = svg.append("defs");
                nodes.forEach(d => {
                    // Only create pattern if not exists
                    if (document.getElementById("img-" + d.id)) return;

                    const imgId = "img-" + d.id;
                    let imgUrl = d.data.photo;
                    if (!imgUrl || imgUrl.includes("undefined")) imgUrl = "/img/icon-192.png"; // Fallback

                    defs.append("pattern")
                        .attr("id", imgId)
                        .attr("height", 1)
                        .attr("width", 1)
                        .attr("patternContentUnits", "objectBoundingBox")
                        .append("image")
                        .attr("height", 1)
                        .attr("width", 1)
                        .attr("preserveAspectRatio", "none")
                        .attr("xlink:href", imgUrl);
                });

                // Overlay Avatar
                nodeEnter.append("circle")
                    .attr("class", "avatar")
                    .attr("r", 15)
                    .style("fill", d => `url(#img-${d.id})`)
                    .style("pointer-events", "none");

                // Labels (Right of node)
                nodeEnter.append("text")
                    .attr("dy", -10)
                    .attr("dx", 25)
                    .attr("text-anchor", "start")
                    .text(d => d.data.name)
                    .style("font-size", "14px")
                    .style("fill", "#FFF")
                    .style("font-weight", "bold")
                    .style("fill-opacity", 0);

                nodeEnter.append("text")
                    .attr("dy", 5)
                    .attr("dx", 25)
                    .attr("text-anchor", "start")
                    .text(d => d.data.role.toUpperCase())
                    .style("font-size", "9px")
                    .style("fill", "#D4AF37")
                    .style("fill-opacity", 0);

                // UPDATE
                const nodeUpdate = node.merge(nodeEnter);

                // Horizontal Translate: X -> Y, Y -> X
                nodeUpdate.transition().duration(500)
                    .attr("transform", d => `translate(${d.y},${d.x})`);

                nodeUpdate.select("circle")
                    .attr("r", 18)
                    .style("fill", d => d._children ? "#D4AF37" : "#0A1128");

                nodeUpdate.selectAll("text").style("fill-opacity", 1);

                // EXIT
                const nodeExit = node.exit().transition().duration(500)
                    .attr("transform", d => `translate(${source.y},${source.x})`)
                    .remove();

                nodeExit.select("circle").attr("r", 1e-6);
                nodeExit.select("text").style("fill-opacity", 1e-6);

                nodes.forEach(d => {
                    d.x0 = d.x;
                    d.y0 = d.y;
                });
            }

            function click(event, d) {
                if (d.children) {
                    d._children = d.children;
                    d.children = null;
                } else {
                    d.children = d._children;
                    d._children = null;
                }
                update(d);
            }

            function horizontalDiagonal(s, d) {
                // Determine layout: S (Source) -> D (Target)
                // We swap X/Y here because d.x is vertical in tree layout, but we want horizontal projection

                // M y1 x1
                // C (y1+y2)/2 x1,
                //   (y1+y2)/2 x2,
                //   y2 x2

                return `M ${s.y} ${s.x}
                        C ${(s.y + d.y) / 2} ${s.x},
                          ${(s.y + d.y) / 2} ${d.x},
                          ${d.y} ${d.x}`;
            }
        }

        // Zoom Controld
        window.zoomIn = () => { svg.transition().call(d3.zoom().scaleBy, 1.2); };
        window.zoomOut = () => { svg.transition().call(d3.zoom().scaleBy, 0.8); };
        window.resetZoom = () => {
            svg.transition().duration(750).call(d3.zoom().transform, d3.zoomIdentity.translate(width / 2, 100));
        };

        init();
    </script>
</body>

</html>