<div class="px-2 pb-32 animate-fade-in-down">

    <!-- HEADER -->
    <div class="mb-8 flex items-center justify-between">
        <a href="/pgm"
            class="text-white/50 hover:text-white transition flex items-center gap-2 text-xs font-bold uppercase tracking-wider">
            <span>←</span> Voltar
        </a>
        <h2 class="font-serif font-bold text-white text-xl">Relatório de Encontro</h2>
    </div>

    <form id="reportForm" class="space-y-8" onsubmit="submitReport(event)">
        <input type="hidden" name="pgmId" id="pgmId" value="{{pgmId}}">
        <input type="hidden" name="leaderUid" id="leaderUid" value="{{user.uid}}">

        <!-- 1. DATA E TIPO -->
        <div class="glass-panel p-6 rounded-[2rem] border border-white/10">
            <div class="flex items-center gap-2 mb-6">
                <span
                    class="bg-imbb-gold text-imbb-navy w-6 h-6 rounded flex items-center justify-center text-xs font-bold">1</span>
                <h3 class="font-bold text-white text-sm uppercase tracking-wide">Dados Gerais</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="text-[10px] uppercase font-bold text-white/40 ml-1 mb-1 block">O que foi?</label>
                    <select name="type" required
                        class="w-full text-sm p-4 bg-black/40 border border-white/10 rounded-xl outline-none focus:border-imbb-gold text-white appearance-none">
                        <option value="normal">Reunião Normal (Célula)</option>
                        <option value="multiplicacao">Multiplicação / Batismo</option>
                        <option value="confraternizacao">Confraternização / Social</option>
                        <option value="evangelismo">Ação Evangelística</option>
                        <option value="discipulado">Discipulado Coletivo</option>
                    </select>
                </div>
                <div>
                    <label class="text-[10px] uppercase font-bold text-white/40 ml-1 mb-1 block">Data do
                        Encontro</label>
                    <input type="datetime-local" name="date" required
                        class="w-full text-sm p-4 bg-black/40 border border-white/10 rounded-xl outline-none focus:border-imbb-gold text-white scheme-dark"
                        value="{{currentDate}}">
                </div>
            </div>
        </div>

        <!-- 2. CHAMADA (Checklist) -->
        <div class="glass-panel p-6 rounded-[2rem] border border-white/10">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-2">
                    <span
                        class="bg-imbb-gold text-imbb-navy w-6 h-6 rounded flex items-center justify-center text-xs font-bold">2</span>
                    <h3 class="font-bold text-white text-sm uppercase tracking-wide">Quem estava presente?</h3>
                </div>
                <div class="text-xs text-white/50 font-bold" id="selectedCount">0 selecionados</div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                {{#each members}}
                <label class="cursor-pointer group relative">
                    <input type="checkbox" name="attendees" value="{{this.uid}}" class="peer hidden"
                        onchange="updateCount()">

                    <div
                        class="glass-panel p-3 rounded-xl border border-white/5 transition-all duration-300 peer-checked:bg-imbb-gold/20 peer-checked:border-imbb-gold peer-checked:scale-[1.02] flex items-center gap-3 opacity-60 peer-checked:opacity-100 hover:opacity-80">
                        <div
                            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center overflow-hidden">
                            {{#if this.photoUrl}}
                            <img src="{{this.photoUrl}}" class="w-full h-full object-cover">
                            {{else}}
                            <span class="text-xs font-bold text-white">{{initials this.name}}</span>
                            {{/if}}
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-bold text-white truncate">{{this.name}}</p>
                            <p class="text-[9px] text-white/40 uppercase tracking-wider peer-checked:text-imbb-gold">
                                {{roleBadge this.role}}
                            </p>
                        </div>
                        <!-- Check Icon -->
                        <div
                            class="w-5 h-5 rounded-full border border-white/20 peer-checked:bg-imbb-gold peer-checked:border-imbb-gold flex items-center justify-center transition">
                            <svg class="w-3 h-3 text-imbb-navy opacity-0 peer-checked:opacity-100" fill="none"
                                stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                    </div>
                </label>
                {{/each}}
            </div>
        </div>

        <!-- 3. VISITANTES -->
        <div class="glass-panel p-6 rounded-[2rem] border border-white/10">
            <div class="flex items-center gap-2 mb-6">
                <span
                    class="bg-imbb-gold text-imbb-navy w-6 h-6 rounded flex items-center justify-center text-xs font-bold">3</span>
                <h3 class="font-bold text-white text-sm uppercase tracking-wide">Visitantes</h3>
            </div>

            <div id="visitorsList" class="space-y-3">
                <!-- Dynamic Inputs -->
            </div>

            <button type="button" onclick="addVisitorField()"
                class="mt-4 w-full py-3 border border-dashed border-white/20 rounded-xl text-xs font-bold text-white/50 hover:text-white hover:border-white/40 transition uppercase tracking-widest flex items-center justify-center gap-2">
                <span>+ Adicionar Visitante</span>
            </button>
        </div>

        <!-- 4. DIÁRIO E FOTO -->
        <div class="glass-panel p-6 rounded-[2rem] border border-white/10">
            <div class="flex items-center gap-2 mb-6">
                <span
                    class="bg-imbb-gold text-imbb-navy w-6 h-6 rounded flex items-center justify-center text-xs font-bold">4</span>
                <h3 class="font-bold text-white text-sm uppercase tracking-wide">Diário & Foto</h3>
            </div>

            <div class="space-y-4">
                <div>
                    <label class="text-[10px] uppercase font-bold text-white/40 ml-1 mb-1 block">Como foi?
                        (Resumo)</label>
                    <textarea name="feedback" rows="4" placeholder="Conte bênçãos, dificuldades ou pedidos de oração..."
                        class="w-full text-sm p-4 bg-black/40 border border-white/10 rounded-xl outline-none focus:border-imbb-gold text-white"></textarea>
                </div>

                <div>
                    <label class="text-[10px] uppercase font-bold text-white/40 ml-1 mb-1 block">Foto do Encontro
                        (Opcional)</label>
                    <div class="relative group">
                        <input type="file" id="photoInput" accept="image/*"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                            onchange="previewPhoto(this)">

                        <div id="photoPreviewBox"
                            class="w-full h-32 bg-black/40 border border-dashed border-white/20 rounded-xl flex flex-col items-center justify-center transition group-hover:border-imbb-gold/50">
                            <div id="uploadIcon" class="text-white/30 mb-2 text-2xl">📸</div>
                            <p id="uploadText" class="text-xs text-white/40 font-bold uppercase tracking-wider">Toque
                                para enviar foto</p>
                            <img id="imgPreview"
                                class="hidden w-full h-full object-cover rounded-xl absolute inset-0 pointer-events-none">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ACTIONS -->
        <!-- ACTIONS -->
        <div class="pt-8 pb-10">
            <button type="submit" id="btnSubmit"
                class="w-full bg-imbb-gold text-imbb-navy font-bold py-5 rounded-2xl shadow-lg shadow-imbb-gold/20 hover:brightness-110 hover:scale-[1.02] transition transform active:scale-95 uppercase text-sm tracking-widest flex items-center justify-center gap-3">
                <span class="text-xl">🚀</span>
                <span>Enviar Relatório</span>
            </button>
            <p class="text-center text-[10px] text-white/30 mt-4 uppercase tracking-widest">Confira os dados antes de
                enviar</p>
        </div>
    </form>
</div>

<script>
    function updateCount() {
        const checked = document.querySelectorAll('input[name="attendees"]:checked').length;
        document.getElementById('selectedCount').innerText = checked + " selecionados";
    }

    function addVisitorField() {
        const div = document.createElement('div');
        div.className = "flex gap-2 animate-fadeIn";
        div.innerHTML = `
            <input type="text" name="visitorName[]" placeholder="Nome" class="flex-1 bg-black/40 border border-white/10 rounded-xl p-3 text-sm text-white outline-none focus:border-white/30">
            <input type="tel" name="visitorPhone[]" placeholder="WhatsApp" class="w-1/3 bg-black/40 border border-white/10 rounded-xl p-3 text-sm text-white outline-none focus:border-white/30">
            <button type="button" onclick="this.parentElement.remove()" class="text-white/30 hover:text-red-400 p-2">✕</button>
        `;
        document.getElementById('visitorsList').appendChild(div);
    }

    function previewPhoto(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                const img = document.getElementById('imgPreview');
                img.src = e.target.result;
                img.classList.remove('hidden');
                document.getElementById('uploadIcon').classList.add('opacity-0');
                document.getElementById('uploadText').classList.add('opacity-0');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // --- CLIENT SIDE COMPRESSION ---
    function compressImage(file, maxWidth, quality) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = event => {
                const img = new Image();
                img.src = event.target.result;
                img.onload = () => {
                    const elem = document.createElement('canvas');
                    let width = img.width;
                    let height = img.height;

                    if (width > maxWidth) {
                        height *= maxWidth / width;
                        width = maxWidth;
                    }

                    elem.width = width;
                    elem.height = height;
                    const ctx = elem.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    resolve(elem.toDataURL('image/jpeg', quality));
                };
                img.onerror = error => reject(error);
            };
            reader.onerror = error => reject(error);
        });
    }

    async function submitReport(e) {
        e.preventDefault();
        const btn = document.getElementById('btnSubmit');
        const form = document.getElementById('reportForm');
        const originalBtnText = btn.innerHTML;

        btn.disabled = true;
        btn.innerHTML = '<span class="animate-pulse">Enviando...</span>';

        try {
            const formData = new FormData(form);

            // Payload Construction
            const payload = {
                pgmId: formData.get('pgmId'),
                leaderUid: formData.get('leaderUid'),
                type: formData.get('type'),
                date: formData.get('date'),
                feedback: formData.get('feedback'),
                attendees: [],
                visitors: []
            };

            // Attendees
            document.querySelectorAll('input[name="attendees"]:checked').forEach(cb => payload.attendees.push(cb.value));

            // Visitors
            const vNames = document.getElementsByName('visitorName[]');
            const vPhones = document.getElementsByName('visitorPhone[]');
            for (let i = 0; i < vNames.length; i++) {
                if (vNames[i].value.trim()) {
                    payload.visitors.push({ name: vNames[i].value, phone: vPhones[i].value });
                }
            }

            // Photo Logic (Compressed)
            const fileInput = document.getElementById('photoInput');
            if (fileInput.files.length > 0) {
                try {
                    const compressedBase64 = await compressImage(fileInput.files[0], 800, 0.7); // Max 800px width, 70% quality
                    payload.photoBase64 = compressedBase64;
                } catch (imgErr) {
                    console.error("Compression failed, trying raw (risky)", imgErr);
                    // Fallback to raw if compression fails (rare)
                }
            }

            await sendData(payload, btn, originalBtnText);

        } catch (err) {
            alert("Erro Inesperado: " + err.message);
            btn.disabled = false;
            btn.innerHTML = originalBtnText;
        }
    }

    async function sendData(payload, btn, originalBtnText) {
        try {
            const res = await fetch('/pgm/report/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!res.ok) throw new Error(res.statusText);

            const d = await res.json();

            if (d.success) {
                // SUCCESS UI FEEDBACK
                btn.className = "w-full bg-green-500 text-white font-bold py-5 rounded-2xl shadow-lg transition uppercase text-sm tracking-widest flex items-center justify-center gap-3";
                btn.innerHTML = '<span class="text-2xl">✓</span> <span>ENVIADO COM SUCESSO!</span>';

                // Redirect trigger
                setTimeout(() => {
                    window.location.href = '/pgm';
                }, 2000); // 2 seconds to see the success message
            } else {
                throw new Error(d.error || "Erro desconhecido no servidor");
            }
        } catch (e) {
            alert("Erro ao Enviar: " + e.message);
            btn.disabled = false;
            btn.className = "w-full bg-red-500 text-white font-bold py-5 rounded-2xl shadow-lg transition uppercase text-sm tracking-widest flex items-center justify-center gap-3";
            btn.innerHTML = "❌ Tentar Novamente";

            // Reset button style after 3 seconds
            setTimeout(() => {
                btn.className = "w-full bg-imbb-gold text-imbb-navy font-bold py-5 rounded-2xl shadow-lg shadow-imbb-gold/20 hover:brightness-110 hover:scale-[1.02] transition transform active:scale-95 uppercase text-sm tracking-widest flex items-center justify-center gap-3";
                btn.innerHTML = originalBtnText;
            }, 3000);
        }
    }
</script>