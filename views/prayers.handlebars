<div class="flex flex-col min-h-screen px-4 pb-32 pt-2 animate-fade-in-down max-w-lg mx-auto">

    <!-- Header -->
    <div class="text-center mb-6">
        <div class="w-16 h-16 bg-imbb-gold/20 rounded-2xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-9 h-9 text-imbb-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
            </svg>
        </div>
        <h1 class="text-xl font-bold text-white">Pedidos de Oração</h1>
        <p class="text-white/50 text-sm mt-1">Compartilhe e interceda pelo seu grupo</p>
    </div>

    <!-- Add prayer button -->
    <button onclick="toggleForm()"
        class="w-full mb-4 flex items-center justify-center gap-2 bg-imbb-gold/10 border border-imbb-gold/30 text-imbb-gold py-3 rounded-2xl font-semibold text-sm hover:bg-imbb-gold/20 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
        </svg>
        Adicionar Pedido
    </button>

    <!-- Add form -->
    <div id="addForm" class="hidden glass-panel rounded-2xl p-5 mb-4">
        <h2 class="text-white font-semibold mb-3">Novo Pedido</h2>
        <textarea id="prayerText" rows="4" maxlength="500" placeholder="Compartilhe seu pedido de oração..."
            class="w-full p-3 rounded-xl bg-black/20 border border-white/10 text-white placeholder-white/30 outline-none focus:border-imbb-gold transition text-sm resize-none"></textarea>
        <div class="flex items-center justify-between mt-3">
            <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="anonymousCheck" class="rounded accent-amber-400">
                <span class="text-white/60 text-sm">Anônimo</span>
            </label>
            <span id="charCount" class="text-white/30 text-xs">0/500</span>
        </div>
        <div class="flex gap-2 mt-3">
            <button onclick="toggleForm()" class="flex-1 py-2 rounded-xl border border-white/20 text-white/60 text-sm hover:bg-white/5 transition">Cancelar</button>
            <button onclick="submitPrayer()" class="flex-1 py-2 rounded-xl bg-imbb-gold text-imbb-navy font-bold text-sm hover:brightness-110 transition">Enviar</button>
        </div>
    </div>

    <!-- Loading -->
    <div id="loadingState" class="text-center py-10 text-white/40 animate-pulse">
        <p>Carregando pedidos...</p>
    </div>

    <!-- Empty state -->
    <div id="emptyState" class="hidden text-center py-10">
        <div class="text-4xl mb-3">🙏</div>
        <p class="text-white/60">Nenhum pedido ainda.</p>
        <p class="text-white/40 text-sm">Seja o primeiro a compartilhar.</p>
    </div>

    <!-- Prayers list -->
    <div id="prayersList" class="space-y-3"></div>
</div>

<!-- Card template (hidden) -->
<template id="prayerCardTemplate">
    <div class="glass-panel rounded-2xl p-4">
        <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center overflow-hidden shrink-0 prayer-photo-wrapper">
                <img class="w-full h-full object-cover prayer-photo hidden" src="">
                <span class="text-white font-bold text-sm prayer-initials"></span>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between gap-2">
                    <span class="text-white font-semibold text-sm prayer-name"></span>
                    <span class="text-white/30 text-xs prayer-date shrink-0"></span>
                </div>
                <p class="text-white/70 text-sm mt-1 leading-relaxed prayer-request"></p>
            </div>
        </div>

        <!-- Answered badge -->
        <div class="prayer-answered-badge hidden mt-2 flex items-center gap-1 text-green-400 text-xs font-bold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Oração Respondida!
        </div>

        <div class="flex items-center justify-between mt-3 pt-3 border-t border-white/10">
            <button class="prayer-pray-btn flex items-center gap-1.5 text-white/50 text-sm hover:text-imbb-gold transition">
                <svg class="w-4 h-4 prayer-pray-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                </svg>
                <span class="prayer-pray-count">0</span> orando
            </button>
            <div class="flex gap-2">
                <button class="prayer-answer-btn hidden text-xs text-green-400 hover:text-green-300 transition px-2 py-1 rounded-lg border border-green-400/30">Respondida ✓</button>
                <button class="prayer-delete-btn hidden text-xs text-red-400 hover:text-red-300 transition px-2 py-1 rounded-lg border border-red-400/30">Remover</button>
            </div>
        </div>
    </div>
</template>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
    import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

    const firebaseConfig = {
        apiKey: "AIzaSyCTB6wkVIfnwx009A67bv8Ar58YpD-59Z8",
        authDomain: "vivendo-como-discipulo.firebaseapp.com",
        projectId: "vivendo-como-discipulo",
        storageBucket: "vivendo-como-discipulo.firebasestorage.app",
        messagingSenderId: "1086407430526",
        appId: "1:1086407430526:web:d57784df6283c51729a32f"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    let idToken = null;

    // Char counter
    document.getElementById('prayerText').addEventListener('input', (e) => {
        document.getElementById('charCount').textContent = `${e.target.value.length}/500`;
    });

    onAuthStateChanged(auth, async (user) => {
        if (!user) { window.location.href = '/login'; return; }
        idToken = await user.getIdToken();
        loadPrayers();
    });

    async function loadPrayers() {
        try {
            const res = await fetch('/api/oracao/list', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${idToken}` }
            });
            const data = await res.json();
            document.getElementById('loadingState').classList.add('hidden');

            if (!data.success || !data.prayers.length) {
                document.getElementById('emptyState').classList.remove('hidden');
                return;
            }

            const list = document.getElementById('prayersList');
            const template = document.getElementById('prayerCardTemplate');

            data.prayers.forEach(p => {
                const card = template.content.cloneNode(true);
                const el = card.querySelector('.glass-panel');

                el.querySelector('.prayer-name').textContent = p.name;
                el.querySelector('.prayer-date').textContent = p.createdAt;
                el.querySelector('.prayer-request').textContent = p.request;
                el.querySelector('.prayer-pray-count').textContent = p.prayCount;

                // Answered badge
                if (p.status === 'answered') {
                    el.querySelector('.prayer-answered-badge').classList.remove('hidden');
                }

                // Photo / initials
                if (p.photoUrl) {
                    el.querySelector('.prayer-photo').src = p.photoUrl;
                    el.querySelector('.prayer-photo').classList.remove('hidden');
                    el.querySelector('.prayer-initials').classList.add('hidden');
                } else {
                    el.querySelector('.prayer-initials').textContent = p.name[0]?.toUpperCase() || '?';
                }

                // Pray button
                const prayBtn = el.querySelector('.prayer-pray-btn');
                if (p.hasPrayed) {
                    prayBtn.querySelector('.prayer-pray-icon').setAttribute('fill', '#C5A059');
                    prayBtn.classList.add('text-imbb-gold');
                    prayBtn.classList.remove('text-white/50');
                }
                prayBtn.addEventListener('click', async () => {
                    const freshToken = await auth.currentUser.getIdToken();
                    const r = await fetch('/api/oracao/pray', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${freshToken}` },
                        body: JSON.stringify({ prayerId: p.id })
                    });
                    const d = await r.json();
                    if (d.success) {
                        prayBtn.querySelector('.prayer-pray-count').textContent = d.prayCount;
                        if (d.hasPrayed) {
                            prayBtn.querySelector('.prayer-pray-icon').setAttribute('fill', '#C5A059');
                            prayBtn.classList.add('text-imbb-gold');
                        } else {
                            prayBtn.querySelector('.prayer-pray-icon').setAttribute('fill', 'none');
                            prayBtn.classList.remove('text-imbb-gold');
                        }
                    }
                });

                // Leader/owner actions
                if (p.isOwner || p.isLeader) {
                    if (p.status === 'active') {
                        el.querySelector('.prayer-answer-btn').classList.remove('hidden');
                        el.querySelector('.prayer-answer-btn').addEventListener('click', async () => {
                            const freshToken = await auth.currentUser.getIdToken();
                            await fetch('/api/oracao/answer', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${freshToken}` },
                                body: JSON.stringify({ prayerId: p.id })
                            });
                            loadPrayers();
                        });
                    }
                    el.querySelector('.prayer-delete-btn').classList.remove('hidden');
                    el.querySelector('.prayer-delete-btn').addEventListener('click', async () => {
                        if (!confirm('Remover este pedido?')) return;
                        const freshToken = await auth.currentUser.getIdToken();
                        await fetch('/api/oracao/delete', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${freshToken}` },
                            body: JSON.stringify({ prayerId: p.id })
                        });
                        loadPrayers();
                    });
                }

                list.appendChild(card);
            });
        } catch (e) {
            document.getElementById('loadingState').textContent = 'Erro ao carregar.';
        }
    }

    window.toggleForm = () => {
        document.getElementById('addForm').classList.toggle('hidden');
        document.getElementById('prayerText').focus();
    };

    window.submitPrayer = async () => {
        const request = document.getElementById('prayerText').value.trim();
        const anonymous = document.getElementById('anonymousCheck').checked;
        if (!request) { alert('Escreva seu pedido.'); return; }

        const freshToken = await auth.currentUser.getIdToken();
        const res = await fetch('/api/oracao/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${freshToken}` },
            body: JSON.stringify({ request, anonymous })
        });
        const data = await res.json();
        if (!data.success) { alert(data.error); return; }

        document.getElementById('prayerText').value = '';
        document.getElementById('addForm').classList.add('hidden');
        document.getElementById('prayersList').innerHTML = '';
        document.getElementById('loadingState').classList.remove('hidden');
        idToken = freshToken;
        loadPrayers();
    };
</script>
