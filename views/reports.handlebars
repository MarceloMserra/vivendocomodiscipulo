<div class="w-full h-full min-h-screen bg-black/90 text-white">
    <!-- Navbar / Header specific for Reports -->
    <div class="bg-black/50 backdrop-blur-md border-b border-white/10 sticky top-0 z-50">
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div class="flex items-center gap-4">
                <a href="/monitoring"
                    class="p-2 rounded-full bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white transition">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                </a>
                <div>
                    <h1 class="text-2xl font-bold font-serif tracking-tight">Relatórios de Frequência</h1>
                    <p class="text-xs text-gray-400">Análise detalhada de crescimento e engajamento.</p>
                </div>
            </div>

            <!-- Filters in Header -->
            <div class="flex flex-wrap gap-2 items-center">
                <input type="date" id="filterStartDate"
                    class="bg-black/40 border-white/10 rounded-lg text-white text-xs py-2 px-3 focus:ring-imbb-gold focus:border-imbb-gold">
                <span class="text-white/30 text-xs">até</span>
                <input type="date" id="filterEndDate"
                    class="bg-black/40 border-white/10 rounded-lg text-white text-xs py-2 px-3 focus:ring-imbb-gold focus:border-imbb-gold">

                <div id="filterPgmWrapper" class="hidden">
                    <select id="filterPgmId"
                        class="bg-black/40 border-white/10 rounded-lg text-white text-xs py-2 px-3 focus:ring-imbb-gold focus:border-imbb-gold max-w-[150px]">
                        <option value="">Todas as PGMs</option>
                    </select>
                </div>

                <button onclick="exportExcel()"
                    class="flex items-center gap-1.5 bg-green-600/80 hover:bg-green-600 text-white text-xs font-bold px-3 py-2 rounded-lg transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                    </svg>
                    Exportar Excel
                </button>
            </div>
        </div>
    </div>

    <!-- LOADER -->
    <div id="pageLoader" class="flex justify-center items-center h-[80vh]">
        <div class="w-16 h-16 border-4 border-imbb-gold border-t-transparent rounded-full animate-spin"></div>
    </div>

    <!-- MAIN CONTENT -->
    <div id="reportsContent" class="hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8 animate-fade-in">

        <!-- KPIs -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <!-- KPI 1 -->
            <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Reuniões</p>
                <h3 class="text-3xl font-black text-white" id="statTotal">-</h3>
            </div>
            <!-- KPI 2 -->
            <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Média</p>
                <h3 class="text-3xl font-black text-white" id="statAvg">-</h3>
            </div>
            <!-- KPI 3 -->
            <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Únicos</p>
                <h3 class="text-3xl font-black text-white" id="statUnique">-</h3>
            </div>
            <!-- KPI 4 -->
            <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Visitantes</p>
                <h3 class="text-3xl font-black text-white" id="statVisitors">-</h3>
            </div>
        </div>

        <!-- CHARTS ROW 1 -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Trend -->
            <div class="bg-white/5 rounded-xl p-6 border border-white/5 lg:col-span-2">
                <h3 class="text-sm font-bold text-white mb-4">Evolução Temporal</h3>
                <div class="h-64 relative"><canvas id="trendChart"></canvas></div>
            </div>
            <!-- Ratio -->
            <div class="bg-white/5 rounded-xl p-6 border border-white/5 flex flex-col items-center justify-center">
                <h3 class="text-sm font-bold text-white mb-4">Membros vs Visitantes</h3>
                <div class="h-48 w-48 relative"><canvas id="ratioChart"></canvas></div>
            </div>
        </div>

        <!-- CHARTS ROW 2 (Ranking) -->
        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
            <h3 class="text-sm font-bold text-white mb-4">Ranking por Supervisão</h3>
            <div class="h-96 relative"><canvas id="rankingChart"></canvas></div>
        </div>

        <!-- TABLE -->
        <div class="bg-white/5 rounded-xl border border-white/5 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-white/10">
                    <thead class="bg-white/5">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase">Data</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase">Grupo</th>
                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase">Total</th>
                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase">Visitantes
                            </th>
                        </tr>
                    </thead>
                    <tbody id="meetingsTableBody" class="divide-y divide-white/10 text-sm text-gray-300"></tbody>
                </table>
            </div>
        </div>

        <!-- ACCESS DENIED -->
        <div id="accessDenied" class="hidden text-center py-20">
            <h3 class="text-xl font-bold text-white">Acesso Restrito</h3>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
    import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

    const firebaseConfig = {
        apiKey: "AIzaSyCTB6wkVIfnwx009A67bv8Ar58YpD-59Z8",
        authDomain: "vivendo-como-discipulo.firebaseapp.com",
        projectId: "vivendo-como-discipulo",
        storageBucket: "vivendo-como-discipulo.firebasestorage.app",
        messagingSenderId: "1086407430526",
        appId: "1:1086407430526:web:d57784df6283c51729a32f",
        measurementId: "G-5JV8QRSMXQ"
    };

    let app; try { app = initializeApp(firebaseConfig); } catch (e) { }
    const auth = getAuth();
    let currentUserToken = null;
    let chartInstances = {};

    onAuthStateChanged(auth, async (user) => {
        if (user) {
            currentUserToken = await user.getIdToken();
            // Init Dates
            const end = new Date();
            const start = new Date();
            start.setDate(start.getDate() - 90);
            document.getElementById('filterStartDate').valueAsDate = start;
            document.getElementById('filterEndDate').valueAsDate = end;
            fetchData();
        } else {
            window.location.href = '/login';
        }
    });

    async function fetchData() {
        showLoader(true);
        try {
            const startDate = document.getElementById('filterStartDate').value;
            const endDate = document.getElementById('filterEndDate').value;
            const pgmId = document.getElementById('filterPgmId').value;
            const res = await fetch('/monitoring/api/data', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${currentUserToken}` },
                body: JSON.stringify({ startDate, endDate, pgmId })
            });

            if (res.status === 403) { document.getElementById('accessDenied').classList.remove('hidden'); return; }
            if (!res.ok) throw new Error('Erro ao carregar');
            const data = await res.json();
            renderReports(data);
        } catch (e) {
            console.error(e);
        } finally {
            showLoader(false);
        }
    }

    function renderReports(data) {
        document.getElementById('reportsContent').classList.remove('hidden');
        const { summary, charts, meetings } = data.dashboard;
        const { permissions, availableLeaders } = data;

        // Admin Filters
        if (permissions.isAdmin) {
            const wrapper = document.getElementById('filterPgmWrapper');
            wrapper.classList.remove('hidden');
            const select = document.getElementById('filterPgmId');
            if (select.options.length <= 1) {
                availableLeaders.forEach(l => {
                    const opt = document.createElement('option');
                    opt.value = l.uid; opt.innerText = l.name;
                    select.appendChild(opt);
                });
            }
        }

        // Stats
        document.getElementById('statTotal').innerText = summary.totalMeetings;
        document.getElementById('statAvg').innerText = summary.avgAttendance;
        document.getElementById('statVisitors').innerText = summary.totalVisitors;
        document.getElementById('statUnique').innerText = summary.uniqueMembers;

        // Charts
        renderTrendChart(charts.trend);
        renderRatioChart(charts.ratio);
        renderRankingChart(charts.bySupervisor);

        // Table
        const tbody = document.getElementById('meetingsTableBody');
        tbody.innerHTML = '';
        meetings.forEach(m => {
            const tr = document.createElement('tr');
            tr.className = "hover:bg-white/5";
            tr.innerHTML = `
                <td class="px-6 py-4 whitespace-nowrap text-white">${new Date(m.date).toLocaleDateString()}</td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-white font-bold">${m.pgmName}</div>
                    <div class="text-xs text-gray-400">${m.supervisorName}</div>
                </td>
                <td class="px-6 py-4 text-center">
                    <span class="px-2 bg-blue-500/20 text-blue-300 rounded-full text-xs font-bold">${m.attendance}</span>
                </td>
                <td class="px-6 py-4 text-center text-gray-400">${m.visitors}</td>
            `;
            tbody.appendChild(tr);
        });
    }

    // Chart Render Functions (Copied & Optimized)
    function renderTrendChart(data) {
        const ctx = document.getElementById('trendChart').getContext('2d');
        if (chartInstances.trend) chartInstances.trend.destroy();
        chartInstances.trend = new Chart(ctx, {
            type: 'line',
            data: {
                labels: data.map(d => new Date(d.date).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' })),
                datasets: [{ label: 'Presença', data: data.map(d => d.count), borderColor: '#C5A059', backgroundColor: 'rgba(197, 160, 89, 0.1)', fill: true, tension: 0.4 }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { display: false }, ticks: { color: '#9CA3AF' } }, y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#9CA3AF' } } } }
        });
    }

    function renderRatioChart(ratio) {
        const ctx = document.getElementById('ratioChart').getContext('2d');
        if (chartInstances.ratio) chartInstances.ratio.destroy();
        chartInstances.ratio = new Chart(ctx, {
            type: 'doughnut',
            data: { labels: ['Membros', 'Visitantes'], datasets: [{ data: [ratio.members, ratio.visitors], backgroundColor: ['#3B82F6', '#EAB308'], borderWidth: 0 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });
    }

    function renderRankingChart(dashboardData) {
        const ctx = document.getElementById('rankingChart').getContext('2d');
        if (chartInstances.ranking) chartInstances.ranking.destroy();
        if (!dashboardData || dashboardData.length === 0) return;

        const labels = dashboardData.map(d => d.name);
        const allPgms = new Set();
        dashboardData.forEach(sup => sup.breakdown.forEach(item => allPgms.add(item.name)));
        const pgmList = Array.from(allPgms).sort();
        const colors = ['#F59E0B', '#3B82F6', '#10B981', '#EF4444', '#8B5CF6'];

        const datasets = pgmList.map((pgmName, index) => ({
            label: pgmName,
            data: labels.map(supLabel => {
                const supData = dashboardData.find(d => d.name === supLabel);
                const pgmData = supData ? supData.breakdown.find(b => b.name === pgmName) : null;
                return pgmData ? pgmData.value : 0;
            }),
            backgroundColor: colors[index % colors.length],
            borderWidth: 0
        }));

        chartInstances.ranking = new Chart(ctx, {
            type: 'bar',
            data: { labels, datasets },
            options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, scales: { x: { stacked: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#9CA3AF' } }, y: { stacked: true, grid: { display: false }, ticks: { color: '#E5E7EB', font: { weight: 'bold' } } } } }
        });
    }

    function showLoader(show) {
        document.getElementById('pageLoader').style.display = show ? 'flex' : 'none';
    }

    ['filterStartDate', 'filterEndDate', 'filterPgmId'].forEach(id => {
        document.getElementById(id).addEventListener('change', fetchData);
    });

    window.exportExcel = async () => {
        const startDate = document.getElementById('filterStartDate').value;
        const endDate = document.getElementById('filterEndDate').value;
        const pgmId = document.getElementById('filterPgmId').value;
        let url = '/monitoring/export?';
        if (startDate) url += `startDate=${startDate}&`;
        if (endDate) url += `endDate=${endDate}&`;
        if (pgmId) url += `pgmId=${pgmId}&`;
        window.location.href = url;
    };
</script>