{{#if data}}

<div class="mb-8 px-2 animate-fade-in-down">
    <div
        class="glass-panel p-4 rounded-2xl shadow-lg border border-white/10 flex justify-between items-center text-white">
        <div>
            <span class="text-[10px] uppercase tracking-wider text-imbb-gold font-bold">Você está lendo</span>
            <p class="text-lg font-serif font-bold">{{data.semana}}</p>
        </div>
        <div class="bg-white/10 p-2 rounded-lg">
            <svg class="w-6 h-6 text-imbb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5">
                </path>
            </svg>
        </div>
    </div>
</div>

{{#if data.noticias}}
<div class="mb-10">
    <div class="flex items-center gap-2 mb-3 px-2">
        <div class="w-1 h-4 bg-imbb-gold rounded-full"></div>
        <h3 class="font-bold text-white text-sm uppercase tracking-wide">Destaques & Missões</h3>
    </div>

    <div id="newsCarousel" class="flex overflow-x-auto space-x-4 pb-4 px-2 no-scrollbar snap-x snap-mandatory"
        onmouseover="pauseCarousel()" onmouseout="resumeCarousel()">

        {{#each data.noticias}}
        <div
            class="min-w-[280px] max-w-[280px] glass-panel p-5 rounded-3xl snap-center flex flex-col justify-between relative group hover:bg-white/10 transition duration-500 border border-white/10">
            <div>
                <span
                    class="bg-imbb-gold text-imbb-navy text-[9px] font-bold px-2 py-1 rounded-md uppercase tracking-wider mb-3 inline-block shadow-sm">{{this.data}}</span>
                <h4 class="font-serif font-bold text-white text-lg leading-tight mb-2 line-clamp-2">{{this.titulo}}</h4>

                {{#if this.link}}
                <a href="https://{{this.link}}" target="_blank"
                    class="flex items-center gap-2 text-[10px] font-bold text-imbb-gold hover:text-white transition mt-2">
                    <span>🔗 ACESSAR LINK EXTERNO</span>
                </a>
                {{/if}}
            </div>
            <button onclick='openModal("{{this.titulo}}", {{json this.conteudo}})'
                class="mt-4 flex items-center justify-between text-xs font-bold text-white/70 group-hover:text-white transition border-t border-white/10 pt-3">
                Ler tudo
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3">
                    </path>
                </svg>
            </button>
        </div>
        {{/each}}
    </div>
</div>
{{/if}}

<div class="space-y-4 px-2 pb-24">
    <div class="flex items-center gap-2 mb-1">
        <div class="w-1 h-4 bg-imbb-gold rounded-full"></div>
        <h3 class="font-bold text-white text-sm uppercase tracking-wide">Devocionais Diários</h3>
    </div>

    {{#each data.devocionais}}
    <div onclick='openReader({{@index}}, {{json this}})'
        class="glass-panel p-6 rounded-[1.5rem] cursor-pointer relative overflow-hidden group hover:bg-white/10 transition duration-300 border border-white/10">

        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition">
            <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path
                    d="M11.25 4.533A9.707 9.707 0 006 3a9.735 9.735 0 00-3.25.555.75.75 0 00-.5.707v14.25a.75.75 0 001 .707A8.237 8.237 0 016 18.75c1.995 0 3.823.707 5.25 1.886V4.533zM12.75 20.636A8.214 8.214 0 0118 18.75c.966 0 1.89.166 2.75.47a.75.75 0 001-.708V4.262a.75.75 0 00-.5-.707A9.735 9.735 0 0018 3a9.707 9.707 0 00-5.25 1.533v16.103z">
                </path>
            </svg>
        </div>

        <div class="relative z-10">
            <span
                class="text-[10px] font-bold tracking-widest text-imbb-gold uppercase mb-1 block">{{this.cabecalho_dia}}</span>
            <h3 class="text-xl font-serif font-bold text-white leading-tight mb-2">{{this.titulo}}</h3>
            <p class="text-xs text-gray-300 font-sans italic border-l-2 border-imbb-gold pl-2">"{{this.texto_base}}"</p>
        </div>

        <div class="mt-5 flex justify-between items-center">
            <span
                class="text-[10px] font-bold text-white/80 flex items-center gap-1 group-hover:translate-x-1 transition">
                LER REFLEXÃO
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </span>
            <div class="h-6 w-6 rounded-full border border-white/30 flex items-center justify-center text-transparent btn-check-preview transition-colors"
                id="preview-check-{{@index}}">✓</div>
        </div>
    </div>
    {{/each}}
</div>

{{#if data.extras}}
<div class="mt-6 pb-32 px-2">
    <div class="flex items-center gap-2 mb-3">
        <div class="w-1 h-4 bg-purple-400 rounded-full"></div>
        <h3 class="font-bold text-white text-sm uppercase tracking-wide">Materiais de Apoio</h3>
    </div>

    <div class="grid grid-cols-1 gap-4">
        {{#each data.extras}}
        <div onclick='openMaterialReader({{json this}})'
            class="glass-panel p-6 rounded-[1.5rem] relative overflow-hidden group hover:bg-white/10 transition duration-300 border border-white/10 cursor-pointer flex items-center justify-between">

            <div class="flex items-center gap-4 relative z-10">
                <div
                    class="w-12 h-12 rounded-full bg-purple-500/20 flex items-center justify-center text-purple-300 border border-purple-500/30 group-hover:scale-110 transition shadow-[0_0_15px_rgba(168,85,247,0.2)]">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25">
                        </path>
                    </svg>
                </div>
                <div>
                    <h4
                        class="font-serif font-bold text-white text-lg leading-tight group-hover:text-purple-200 transition">
                        {{this.titulo}}</h4>
                    <p
                        class="text-[10px] text-white/40 uppercase tracking-widest mt-1 group-hover:text-white/60 transition">
                        Toque para ler</p>
                </div>
            </div>

            <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-white/30 group-hover:bg-white/10 group-hover:text-white transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </div>

            <!-- Decorative bg glow -->
            <div
                class="absolute -right-4 -bottom-4 w-24 h-24 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition">
            </div>
        </div>
        {{/each}}
    </div>
</div>
{{/if}}

<div id="readerModal" class="fixed inset-0 z-[9999] hidden transition-opacity duration-300">

    <div class="absolute inset-0 bg-black/95 backdrop-blur-xl" onclick="closeReader()"></div>

    <!-- Custom Style to Force Gold Colors in Prose -->
    <style>
        #modalText strong {
            color: #d4af37 !important;
            font-weight: 800;
        }

        #modalText ol {
            list-style-type: decimal;
            padding-left: 1.5rem;
        }

        #modalText li::marker {
            color: #d4af37 !important;
            font-weight: bold;
        }

        #modalText li {
            padding-left: 0.5rem;
            margin-bottom: 1rem;
        }
    </style>

    <div id="readerCard"
        class="absolute bottom-0 left-0 md:left-1/2 md:-translate-x-1/2 w-full md:max-w-md h-[92dvh] bg-[#0A1635] rounded-t-[2rem] shadow-2xl transform translate-y-full transition-transform duration-300 border-t border-white/10 flex flex-col">

        <div
            class="bg-[#0F265C] w-full shrink-0 flex justify-between items-center px-6 py-4 rounded-t-[2rem] border-b border-white/10 shadow-lg relative z-50">

            <div class="absolute top-2 left-1/2 -translate-x-1/2 w-12 h-1.5 bg-white/20 rounded-full"></div>

            <div class="w-10"></div> <button onclick="closeReader()"
                class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-white hover:bg-red-500/20 hover:text-red-400 transition mt-2">
                <span class="text-xl font-bold">✕</span>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto bg-[#0A1635] p-6 pb-20 no-scrollbar relative">

            <span id="modalDate"
                class="text-xs font-bold tracking-widest text-imbb-gold uppercase block mb-3 text-center opacity-80 mt-2"></span>
            <h2 id="modalTitle" class="text-2xl font-serif font-bold text-white leading-tight mb-8 text-center"></h2>

            <div class="text-center mb-10">
                <a id="modalBibleLink" target="_blank"
                    class="inline-flex items-center gap-2 px-5 py-3 bg-white/5 text-white text-xs font-bold rounded-full hover:bg-white/10 transition border border-white/10 shadow-lg">
                    📖 Ler Texto Bíblico
                </a>
            </div>

            <div id="modalText"
                class="prose prose-invert prose-lg text-gray-300 leading-relaxed font-serif text-justify mb-12 first-letter:text-5xl first-letter:font-bold first-letter:text-imbb-gold first-letter:mr-3 first-letter:float-left">
            </div>

            <div id="modalAnnualBox" class="mb-10 p-5 bg-white/5 rounded-2xl border border-white/10 hidden">
                <p class="text-[10px] uppercase font-bold text-imbb-gold mb-4 flex items-center">
                    <span class="mr-2 text-lg">📅</span> Leitura Bíblica Anual
                </p>
                <div id="modalAnnualLinks" class="flex flex-wrap gap-2"></div>
            </div>

            <button id="modalCheckBtn" onclick="toggleReadModal()"
                class="w-full py-4 rounded-xl border border-white/20 text-white/50 font-bold mb-10 flex items-center justify-center gap-3 hover:bg-white/5 transition group">
                <span class="check-icon text-2xl group-hover:scale-110 transition">○</span> Marcar como Lido
            </button>

            <div class="bg-[#0F1E45] p-6 rounded-3xl shadow-lg border border-white/5 mb-10">
                <h3 class="font-bold text-white mb-4 flex items-center gap-2 text-sm uppercase tracking-wide">
                    <span class="text-imbb-gold">💬</span> Espaço de Comunhão
                </h3>
                <div id="modalQuestion"
                    class="text-sm text-blue-200 bg-imbb-blue/20 p-5 rounded-2xl mb-6 italic font-medium border-l-4 border-imbb-blue">
                </div>
                <div id="modalCommentsList" class="space-y-4 mb-6 max-h-60 overflow-y-auto pr-2"></div>
                <form action="/comentar" method="POST" class="flex gap-2 relative">
                    <input type="hidden" name="boletimId" value="{{data.uid}}">
                    <input type="hidden" name="devocionalIndex" id="modalIndexInput">
                    <input type="hidden" name="userUid" class="input-user-uid">
                    <input type="hidden" name="userPgm" class="input-user-pgm">
                    <input type="hidden" name="nome" class="input-user-name">
                    <input name="texto" placeholder="Compartilhe sua reflexão..." required
                        class="flex-1 bg-black/30 rounded-full px-5 py-4 text-sm text-white placeholder-white/30 outline-none border border-white/10 focus:border-imbb-gold transition shadow-inner">
                    <button type="submit"
                        class="absolute right-2 top-2 bg-imbb-gold text-imbb-navy w-10 h-10 rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition font-bold text-lg">➤</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="newsModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 backdrop-blur-md p-6">
    <div
        class="glass-panel w-full max-w-sm rounded-3xl p-8 shadow-2xl relative animate-bounce-in border border-white/10">
        <button onclick="document.getElementById('newsModal').classList.add('hidden')"
            class="absolute top-4 right-4 text-white/50 hover:text-white">✕</button>
        <h3 id="newsModalTitle" class="text-xl font-serif font-bold text-white mb-4 pr-6 leading-tight"></h3>
        <div class="h-1 w-12 bg-imbb-gold rounded-full mb-6"></div>
        <div id="newsModalContent"
            class="text-gray-300 text-sm leading-relaxed max-h-[60vh] overflow-y-auto font-sans text-justify pr-2">
        </div>
    </div>
</div>

{{else}}
<div class="glass-panel p-8 rounded-3xl text-center mt-20 mx-2">
    <div class="animate-pulse mb-4 text-4xl">⛪</div>
    <h2 class="text-xl font-bold text-white">Carregando Boletim...</h2>
</div>
{{/if}}

<script>
    // CARROSSEL
    let carouselInterval;
    const carousel = document.getElementById('newsCarousel');
    function startCarousel() {
        if (!carousel) return;
        carouselInterval = setInterval(() => {
            if (carousel.scrollLeft + carousel.clientWidth >= carousel.scrollWidth) {
                carousel.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
                carousel.scrollBy({ left: 300, behavior: 'smooth' });
            }
        }, 4000);
    }
    function pauseCarousel() { clearInterval(carouselInterval); }
    function resumeCarousel() { startCarousel(); }
    document.addEventListener('DOMContentLoaded', startCarousel);

    // LÓGICA DO MODAL
    let currentDevocionalId = null;

    function openModal(title, content) {
        document.getElementById('newsModalTitle').innerText = title;
        document.getElementById('newsModalContent').innerHTML = content;
        document.getElementById('newsModal').classList.remove('hidden');
        document.getElementById('newsModal').classList.add('flex');
    }

    function openMaterialReader(data) {
        const modal = document.getElementById('readerModal');
        const card = document.getElementById('readerCard');
        document.querySelector('main').style.overflow = 'hidden';

        // Reset/Hide Devotional specific fields
        document.getElementById('modalDate').innerText = "Material de Apoio";
        document.getElementById('modalBibleLink').classList.add('hidden');
        document.getElementById('modalAnnualBox').classList.add('hidden');
        document.getElementById('modalQuestion').parentElement.classList.add('hidden'); // Hide Comments Box
        document.getElementById('modalCheckBtn').classList.add('hidden'); // Hide Read Button

        // Set Content
        document.getElementById('modalTitle').innerText = data.titulo;
        // Inject HTML with the sophisticated classes - ADDED SUPPORT FOR OL/LI
        document.getElementById('modalText').className = "prose prose-invert prose-lg text-gray-300 leading-8 font-serif text-justify mb-12 prose-p:mb-6 prose-strong:text-imbb-gold prose-strong:font-bold prose-ul:list-disc prose-ul:pl-5 prose-ol:list-decimal prose-ol:pl-5 prose-li:marker:text-imbb-gold max-w-none";
        document.getElementById('modalText').innerHTML = data.conteudo;

        modal.classList.remove('hidden');
        setTimeout(() => card.classList.remove('translate-y-full'), 10);
    }

    // Capture standard prose classes to restore them when opening standard devotions
    const standardProseClass = "prose prose-invert prose-lg text-gray-300 leading-relaxed font-serif text-justify mb-12 first-letter:text-5xl first-letter:font-bold first-letter:text-imbb-gold first-letter:mr-3 first-letter:float-left";

    function openReader(index, data) {
        currentDevocionalId = 'card-' + index;
        const modal = document.getElementById('readerModal');
        const card = document.getElementById('readerCard');

        // TRAVA SCROLL DO MAIN
        document.querySelector('main').style.overflow = 'hidden';

        // RESTORE DEVOTIONAL SPECIFIC UI
        document.getElementById('modalBibleLink').classList.remove('hidden');
        document.getElementById('modalQuestion').parentElement.classList.remove('hidden'); // Show Comments
        document.getElementById('modalCheckBtn').classList.remove('hidden'); // Show Read Button

        // Restore Standard Typography
        document.getElementById('modalText').className = standardProseClass;

        document.getElementById('modalDate').innerText = data.cabecalho_dia || data.dia_semana;
        document.getElementById('modalTitle').innerText = data.titulo;
        document.getElementById('modalText').innerHTML = data.conteudo; // Removed .replace, assuming HTML from backend

        const questionBox = document.getElementById('modalQuestion');
        if (data.pergunta_reflexao) { questionBox.innerText = data.pergunta_reflexao; questionBox.classList.remove('hidden'); }
        else { questionBox.classList.add('hidden'); }

        const verseLink = document.getElementById('modalBibleLink');
        verseLink.href = `https://www.bibliaonline.com.br/nvi/busca?q=${encodeURIComponent(data.texto_base)}`;
        verseLink.innerHTML = `📖 Ler ${data.texto_base}`;

        const annualBox = document.getElementById('modalAnnualBox');
        const annualLinks = document.getElementById('modalAnnualLinks');
        if (data.leitura_anual) {
            annualBox.classList.remove('hidden');
            annualLinks.innerHTML = '';
            data.leitura_anual.split(/[,;]/).forEach(ref => {
                const cleanRef = ref.trim().replace(/\.$/, '');
                if (cleanRef.length > 2) {
                    annualLinks.innerHTML += `<a href="https://www.bibliaonline.com.br/nvi/busca?q=${encodeURIComponent(cleanRef)}" target="_blank" class="px-4 py-2 bg-white/10 text-white text-xs font-bold border border-white/20 rounded-lg hover:bg-imbb-gold hover:text-imbb-navy hover:border-imbb-gold transition shadow-sm flex items-center gap-2">${cleanRef} ↗</a>`;
                }
            });
        } else { annualBox.classList.add('hidden'); }

        const commentsDiv = document.getElementById('modalCommentsList');
        commentsDiv.innerHTML = '';
        if (data.comentarios && data.comentarios.length > 0) {
            data.comentarios.forEach(c => {
                commentsDiv.innerHTML += `<div class="text-sm bg-black/20 p-4 rounded-xl border border-white/5"><div class="flex justify-between items-center mb-1"><span class="font-bold text-imbb-gold text-xs uppercase tracking-wide">${c.nome}</span>${canDelete(c) ? `<form action="/comentario/delete" method="POST" onsubmit="return confirm('Apagar?')"><input type="hidden" name="commentId" value="${c.id}"><button class="text-white/20 hover:text-red-400 text-xs">REMOVER</button></form>` : ''}</div><p class="text-gray-300 leading-relaxed">${c.texto}</p></div>`;
            });
        } else { commentsDiv.innerHTML = '<p class="text-xs text-white/30 text-center italic py-4">Seja o primeiro a compartilhar uma reflexão.</p>'; }

        document.getElementById('modalIndexInput').value = index;
        updateModalCheckButton();
        modal.classList.remove('hidden');
        setTimeout(() => card.classList.remove('translate-y-full'), 10);
    }

    function closeReader() {
        const modal = document.getElementById('readerModal');
        const card = document.getElementById('readerCard');
        document.querySelector('main').style.overflow = ''; // DESTRAVA SCROLL MAIN
        card.classList.add('translate-y-full');
        setTimeout(() => modal.classList.add('hidden'), 300);
    }

    function canDelete(comment) {
        const myUid = localStorage.getItem('userUid');
        const myRole = localStorage.getItem('userRole');
        return (comment.authorUid === myUid || myRole === 'admin');
    }

    function updateModalCheckButton() {
        const btn = document.getElementById('modalCheckBtn');
        const isRead = localStorage.getItem(currentDevocionalId) === 'true';
        if (isRead) {
            btn.className = "w-full py-4 rounded-xl bg-green-600 text-white font-bold mb-10 flex items-center justify-center gap-3 shadow-lg transition border-none";
            btn.innerHTML = '<span class="text-xl">✓</span> Leitura Concluída';
        } else {
            btn.className = "w-full py-4 rounded-xl border border-white/20 text-white/50 font-bold mb-10 flex items-center justify-center gap-3 hover:bg-white/5 transition";
            btn.innerHTML = '<span class="text-xl">○</span> Marcar como Lido';
        }
        const idx = currentDevocionalId.split('-')[1];
        const prev = document.getElementById(`preview-check-${idx}`);
        if (prev) {
            if (isRead) { prev.classList.add('bg-green-500', 'border-none', 'text-white'); prev.innerText = '✓'; }
            else { prev.classList.remove('bg-green-500', 'border-none', 'text-white'); prev.innerText = ''; }
        }
    }

    function toggleReadModal() {
        const isRead = localStorage.getItem(currentDevocionalId) === 'true';
        if (isRead) localStorage.removeItem(currentDevocionalId); else localStorage.setItem(currentDevocionalId, 'true');
        updateModalCheckButton();
    }

    document.addEventListener('DOMContentLoaded', () => {
        const uid = localStorage.getItem('userUid');
        const name = localStorage.getItem('userName');
        document.querySelectorAll('.input-user-uid').forEach(el => el.value = uid);
        document.querySelectorAll('.input-user-name').forEach(el => el.value = name);
        document.querySelectorAll('.btn-check-preview').forEach(el => {
            const idx = el.id.split('-')[2];
            if (localStorage.getItem(`card-${idx}`) === 'true') { el.classList.add('bg-green-500', 'border-none', 'text-white'); el.innerText = '✓'; }
        });
    });
</script>